# =========================
# Firebase platform config files
# Berisi OAuth client IDs, SHA-1 certificate hash, dan API keys client-side.
# Meskipun bukan secret sejati (nilai ini juga ada di APK/IPA setelah build),
# file ini sebaiknya tidak di-commit agar tiap developer/environment
# men-download versi terbaru dari Firebase Console.
#
# Cara mendapatkan kembali:
#   Android : Firebase Console → Project Settings → google-services.json
#   iOS     : Firebase Console → Project Settings → GoogleService-Info.plist
#   Dart    : jalankan `flutterfire configure` (regenerate lib/firebase_options.dart)
#
# Template tersedia di:
#   android/app/google-services.example.json
#   ios/Runner/GoogleService-Info.example.plist
# =========================
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# =========================
# Local env / machine-specific
# =========================
.env
.env.*
*.local

