# =========================
# Firebase — konfigurasi klien (gitignored)
#
# File-file ini berisi konfigurasi Firebase yang spesifik untuk setiap
# project/developer. Tidak di-commit agar setiap developer menggunakan
# project Firebase mereka sendiri dan repository aman dipublikasikan.
#
# Cara mendapatkan/membuat:
#   Dart    : salin lib/firebase_options.example.dart → lib/firebase_options.dart
#             lalu isi nilai dari Firebase Console, ATAU jalankan:
#               dart pub global activate flutterfire_cli
#               flutterfire configure
#   Android : Firebase Console → Project Settings → Android app → Download
#             → letakkan di android/app/google-services.json
#   iOS     : Firebase Console → Project Settings → iOS app → Download
#             → letakkan di ios/Runner/GoogleService-Info.plist
#
# Template (placeholder, tidak ada nilai nyata) tersedia di:
#   lib/firebase_options.example.dart
#   android/app/google-services.example.json
#   ios/Runner/GoogleService-Info.example.plist
# =========================
lib/firebase_options.dart
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

